local _wfConns={}; local _wfActive=false
local function startWalkFling()
    _wfActive=true
    table.insert(_wfConns,RunService.Stepped:Connect(function()
        if not _wfActive then return end
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=player and p.Character then for _,part in ipairs(p.Character:GetChildren()) do if part:IsA("BasePart") then part.CanCollide=false end end end
        end
    end))
    local co=coroutine.create(function()
        while _wfActive do
            RunService.Heartbeat:Wait(); local char=player.Character; local root=char and char:FindFirstChild("HumanoidRootPart")
            if not root then RunService.Heartbeat:Wait(); continue end
            local vel=root.Velocity; root.Velocity=vel*10000+Vector3.new(0,10000,0)
            RunService.RenderStepped:Wait(); if root and root.Parent then root.Velocity=vel end
            RunService.Stepped:Wait(); if root and root.Parent then root.Velocity=vel+Vector3.new(0,0.1,0) end
        end
    end)
    coroutine.resume(co); table.insert(_wfConns,co)
end
local function stopWalkFling()
    _wfActive=false
    for _,c in ipairs(_wfConns) do
        if typeof(c)=="RBXScriptConnection" then c:Disconnect() elseif typeof(c)=="thread" then pcall(task.cancel,c) end
    end; _wfConns={}
end

local function findNearestEnemy(myHRP)
    local nearest,nd,nt=nil,math.huge,nil
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            local eh=p.Character:FindFirstChild("HumanoidRootPart")
            local torso=p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if eh and hum and hum.Health>0 then
                local d=(eh.Position-myHRP.Position).Magnitude
                if d<nd and d<=AimbotRadius then nd=d; nearest=eh; nt=torso or eh end
            end
        end
    end
    return nearest,nd,nt
end
local function startBatAimbot()
    if batAimbotConn then return end
    batAimbotConn=RunService.Heartbeat:Connect(function()
        local c=player.Character; if not c then return end
        local h=c:FindFirstChild("HumanoidRootPart"); local hum=c:FindFirstChildOfClass("Humanoid"); if not h or not hum then return end
        local bat=findBat(); if bat and bat.Parent~=c then hum:EquipTool(bat) end
        local target,_,torso=findNearestEnemy(h)
        if target and torso then
            local pp=torso.Position+(torso.AssemblyLinearVelocity*0.13); local dir=pp-h.Position
            if Vector3.new(dir.X,0,dir.Z).Magnitude>0 then hum.AutoRotate=true end
            if dir.Magnitude>1.5 then h.AssemblyLinearVelocity=dir.Unit*BatAimbotSpeed
            else h.AssemblyLinearVelocity=target.AssemblyLinearVelocity end
        end
    end)
end
local function stopBatAimbot() if batAimbotConn then batAimbotConn:Disconnect(); batAimbotConn=nil end end

-- Counter hit (ragdoll-based)
local function findNearestEnemyForCounter()
    local char=player.Character; if not char then return nil,nil end
    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil,nil end
    local nearest,nd,nc=nil,math.huge,nil
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            local eh=p.Character:FindFirstChild("HumanoidRootPart"); local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if eh and hum and hum.Health>0 then
                local d=(eh.Position-hrp.Position).Magnitude; if d<nd and d<70 then nd=d; nearest=eh; nc=p.Character end
            end
        end
    end
    return nearest,nc
end
local function doCounterHit()
    if counterCooldown then return end; counterCooldown=true
    task.spawn(function()
        task.wait(0.25)
        local char=player.Character; if not char then counterCooldown=false; return end
        local hrp=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then counterCooldown=false; return end
        local bat=findBat(); if bat and bat.Parent~=char then hum:EquipTool(bat) end; task.wait(0.08)
        local targetHRP,targetChar=findNearestEnemyForCounter(); if not targetHRP then counterCooldown=false; return end
        for _=1,COUNTER_SWINGS do
            local tHum=targetChar and targetChar:FindFirstChildOfClass("Humanoid"); if not tHum or tHum.Health<=0 then break end
            char=player.Character; if not char then break end; hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then break end
            local dir=targetHRP.Position-hrp.Position; if dir.Magnitude>0.5 then hrp.AssemblyLinearVelocity=dir.Unit*COUNTER_RUSH_SPEED end
            local ct=char:FindFirstChildOfClass("Tool"); if ct then
                local rem=ct:FindFirstChildWhichIsA("RemoteEvent",true); if rem then pcall(function() rem:FireServer() end) end
                local cd=ct:FindFirstChildWhichIsA("ClickDetector",true); if cd then pcall(function() fireclickdetector(cd) end) end
                pcall(function() ct.Activated:Fire() end)
            end; task.wait(0.1)
        end
        task.wait(0.05); local cf=player.Character; if cf then local hf=cf:FindFirstChild("HumanoidRootPart"); if hf then hf.AssemblyLinearVelocity=Vector3.new(0,hf.AssemblyLinearVelocity.Y,0) end end
        task.wait(0.7); counterCooldown=false
    end)
end
local function startCounterHit()
    if counterHitConn then counterHitConn:Disconnect(); counterHitConn=nil end
    wasRagdolledForCounter=false; counterCooldown=false
    counterHitConn=RunService.Heartbeat:Connect(function()
        if not counterHitActive then return end
        local char=player.Character; if not char then return end
        local nowRag=isRagdolled(char)
