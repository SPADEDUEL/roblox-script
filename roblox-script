-- FocusLost updates the data table, rebuilds waypoints, and refreshes the marker
local function makeWaypointEditor(parent,side,index,data)
    local row=Instance.new("Frame",parent); row.Size=UDim2.new(1,0,0,30)
    row.BackgroundColor3=Color3.fromRGB(248,248,248); row.BackgroundTransparency=0
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,7)
    local ist=Instance.new("UIStroke",row); ist.Color=C_BORDER; ist.Thickness=1; ist.Transparency=0.4
    local displayKey = (side=="right" and "R" or "L")..index
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(0,28,1,0); lbl.Position=UDim2.new(0,4,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=displayKey; lbl.TextColor3=C_ACTIVE; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=10; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local coords={"x","y","z"}; local fields={}
    for i,coord in ipairs(coords) do
        local box=Instance.new("TextBox",row)
        box.Size=UDim2.new(0,52,0,22); box.Position=UDim2.new(0,30+(i-1)*56,0.5,-11)
        box.BackgroundColor3=Color3.fromRGB(235,235,235); box.BorderSizePixel=0
        Instance.new("UICorner",box).CornerRadius=UDim.new(0,5)
        local bs=Instance.new("UIStroke",box); bs.Color=C_BORDER; bs.Thickness=1; bs.Transparency=0.5
        box.Text=tostring(data[coord]); box.TextColor3=C_TEXT; box.Font=Enum.Font.Gotham; box.TextSize=9; box.PlaceholderText=coord
        box.ClearTextOnFocus=false
        box.FocusLost:Connect(function()
            local v=tonumber(box.Text)
            if v then
                data[coord]=v
                if side=="right" then rightWaypoints=buildWaypoints(rightWaypointData)
                else leftWaypoints=buildWaypoints(leftWaypointData) end
                refreshMarker(side,index)  -- move the ball immediately
            else
                box.Text=tostring(data[coord])
            end
        end)
        fields[coord]=box
    end
    if not waypointFields[side] then waypointFields[side]={} end
    waypointFields[side][index]=fields
    return row
end

