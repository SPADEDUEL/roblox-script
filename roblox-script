-- ============================================================
-- WAYPOINT MARKER SYSTEM
-- Uses Highlight + SelectionBox on transparent parts so they
-- work correctly from a LocalScript with CoreGui parent.
-- Parts live in a Folder under workspace (created at runtime).
-- ============================================================
local showWaypointsEnabled = false
local waypointMarkers      = {}   -- key "R1".."L4" â†’ Part
local waypointFields       = {}   -- [side][index] = {x,y,z} TextBox refs

local markerFolder
local rightMarkerColor = Color3.fromRGB(220, 30,  30)
local leftMarkerColor  = Color3.fromRGB(220, 80, 180)

local function ensureMarkerFolder()
    if not markerFolder or not markerFolder.Parent then
        -- Clean up old one if orphaned
        local old = workspace:FindFirstChild("SpadeWPMarkers")
        if old then old:Destroy() end
        markerFolder = Instance.new("Folder")
        markerFolder.Name = "SpadeWPMarkers"
        markerFolder.Parent = workspace
    end
end

local function createMarker(key, pos, color, labelText)
    ensureMarkerFolder()
    -- Remove old marker for this key
    if waypointMarkers[key] and waypointMarkers[key].Parent then
        waypointMarkers[key]:Destroy()
    end

    local part = Instance.new("Part")
    part.Name       = "WP_"..key
    part.Shape      = Enum.PartType.Ball
    part.Size       = Vector3.new(1.6, 1.6, 1.6)
    part.CFrame     = CFrame.new(pos)
    part.Anchored   = true
    part.CanCollide = false
    part.CastShadow = false
    part.Transparency = 0.3
    part.Color      = color
    part.Material   = Enum.Material.Neon
    part.Parent     = markerFolder

    -- BillboardGui for the label (parented to part â€” works from LocalScript)
    local bb = Instance.new("BillboardGui")
    bb.Size          = UDim2.new(0, 54, 0, 22)
    bb.StudsOffset   = Vector3.new(0, 1.6, 0)
    bb.AlwaysOnTop   = true
    bb.LightInfluence = 0
    bb.Parent        = part

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size                  = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundColor3      = color
    lbl.BackgroundTransparency = 0.08
    lbl.Text                  = labelText
    lbl.TextColor3            = Color3.fromRGB(255, 255, 255)
    lbl.Font                  = Enum.Font.GothamBold
    lbl.TextSize              = 12
    lbl.TextStrokeTransparency = 0.3
    Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 6)

    waypointMarkers[key] = part
end

local function showAllMarkers()
    for i, d in ipairs(rightWaypointData) do
        createMarker("R"..i, Vector3.new(d.x, d.y, d.z), rightMarkerColor, "R"..i)
    end
    for i, d in ipairs(leftWaypointData) do
        createMarker("L"..i, Vector3.new(d.x, d.y, d.z), leftMarkerColor, "L"..i)
    end
end

local function hideAllMarkers()
    for _, m in pairs(waypointMarkers) do
        if m and m.Parent then m:Destroy() end
    end
    waypointMarkers = {}
    if markerFolder and markerFolder.Parent then markerFolder:Destroy() end
    markerFolder = nil
end

local function refreshMarker(side, index)
    if not showWaypointsEnabled then return end
    local key, data, color
    if side == "right" then
        key = "R"..index; data = rightWaypointData[index]; color = rightMarkerColor
    else
        key = "L"..index; data = leftWaypointData[index]; color = leftMarkerColor
    end
    if data then
        createMarker(key, Vector3.new(data.x, data.y, data.z), color, key)
    end
end

