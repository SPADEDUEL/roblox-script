local settingsRegistry={}
local function registerToggle(name,item,onFn,offFn)
    local dot=item:FindFirstChild("StatusDot")
    settingsRegistry[name]={
        item=item,
        getState=function() return dot.BackgroundColor3==C_DOT_ON end,
        activate=function()
            item.BackgroundColor3=Color3.fromRGB(255,235,235); if dot then dot.BackgroundColor3=C_DOT_ON end
            local l=item:FindFirstChild("Label"); if l then l.TextColor3=C_ACTIVE end
            if onFn then onFn() end
        end,
        deactivate=function()
            item.BackgroundColor3=Color3.fromRGB(248,248,248); if dot then dot.BackgroundColor3=C_DOT_OFF end
            local l=item:FindFirstChild("Label"); if l then l.TextColor3=C_TEXT end
            if offFn then offFn() end
        end,
    }
    item.MouseButton1Click:Connect(function()
        if settingsRegistry[name].getState() then settingsRegistry[name].deactivate() else settingsRegistry[name].activate() end
    end)
end

